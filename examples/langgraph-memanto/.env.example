# Required: Moorcheh API key for Memanto's semantic memory backend.
# Get one at https://console.moorcheh.ai/api-keys (free tier: 100K ops/month).
MOORCHEH_API_KEY=

# Required: OpenRouter API key for the LangGraph agent's LLM.
# Get yours at https://openrouter.ai/keys (free tier available).
OPENROUTER_API_KEY=

# Optional: Override the LLM model used by the LangGraph agent.
#
# Default: openai/gpt-oss-120b:free
#   Fastest free model on OpenRouter for KIND::CONTENT line extraction
#   (~3s for 5 facts). Subject to shared free-tier rate limits.
#
# Other free options:
#   openai/gpt-oss-20b:free                 (4 memories, ~20s, slow but consistent)
#   nvidia/nemotron-3-super-120b-a12b:free  (3 memories, ~9s, sometimes merges facts)
#   google/gemma-4-26b-a4b-it:free          (fast but inconsistent across runs)
#
# Paid options - require credits at https://openrouter.ai/credits:
#   tencent/hy3-preview            REASONING model, best extraction quality.
#     Requires OpenRouter key credit limit >= $5: it reserves max_tokens=7000
#     per call (default in graph.py) and the graph makes 2 sequential calls per
#     turn, so a $1 key limit drains below the reservation and the second call
#     returns empty output.
#   openai/gpt-4o-mini             ~$0.15/1M tokens, near-instant, very cheap
#   anthropic/claude-haiku-4.5     cheap, fast, reliable
#
# LANGGRAPH_LLM=openai/gpt-oss-120b:free
