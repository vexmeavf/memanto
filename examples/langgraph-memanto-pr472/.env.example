# Memanto (Moorcheh) API Key — get yours at https://console.moorcheh.ai/api-keys
MOORCHEH_API_KEY=mch_your_api_key_here

# LLM API Key (for LangGraph agent's LLM calls)
# Choose ONE: OpenRouter, OpenAI, or Anthropic
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# OPENAI_API_KEY=sk-your_key_here
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: Model override (default: openrouter/google/gemini-2.0-flash-001)
# LLM_MODEL=openai/gpt-4o-mini
